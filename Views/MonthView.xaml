<UserControl x:Class="HomeschoolPlanner.Views.MonthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- Day-of-week headers -->
            <RowDefinition Height="Auto" />
            <!-- Calendar grid -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Day-of-week header row -->
        <UniformGrid x:Name="DowHeader" Grid.Row="0" Rows="1" Columns="7" Margin="0,0,0,4">
            <TextBlock Text="Mon" HorizontalAlignment="Center" FontSize="12" Foreground="#6B7280" />
            <TextBlock Text="Tue" HorizontalAlignment="Center" FontSize="12" Foreground="#6B7280" />
            <TextBlock Text="Wed" HorizontalAlignment="Center" FontSize="12" Foreground="#6B7280" />
            <TextBlock Text="Thu" HorizontalAlignment="Center" FontSize="12" Foreground="#6B7280" />
            <TextBlock Text="Fri" HorizontalAlignment="Center" FontSize="12" Foreground="#6B7280" />
            <TextBlock Text="Sat" HorizontalAlignment="Center" FontSize="12" Foreground="#6B7280" />
            <TextBlock Text="Sun" HorizontalAlignment="Center" FontSize="12" Foreground="#6B7280" />
        </UniformGrid>

        <!-- Calendar day cells - built in code-behind -->
        <UniformGrid x:Name="CalendarGrid" Grid.Row="1" Columns="7" />
    </Grid>

</UserControl>
