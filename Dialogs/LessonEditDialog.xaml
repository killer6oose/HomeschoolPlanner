<Window x:Class="HomeschoolPlanner.Dialogs.LessonEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Subject Details"
        Width="520" Height="620"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource DialogBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel>
                <TextBlock x:Name="SubjectLabel" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock x:Name="DateLabel" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0" />
            </StackPanel>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,8">
            <StackPanel>

                <!-- ============================================================ -->
                <!-- LESSONS -->
                <!-- ============================================================ -->
                <Expander Header="Lessons" IsExpanded="True"
                          Margin="0,8,0,8"
                          Foreground="{DynamicResource TextPrimaryBrush}">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="5" Padding="14,10">
                        <StackPanel>

                            <!-- Lesson items (code-built) -->
                            <StackPanel x:Name="LessonItemsPanel" Margin="0,0,0,8" />

                            <!-- Add lesson form -->
                            <Border Background="{DynamicResource DialogBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="10,8"
                                    Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock Text="Add a lesson" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="Title" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2" />
                                    <TextBox x:Name="NewLessonTitle" Margin="0,0,0,6" />
                                    <TextBlock Text="Sub-title / description (optional)" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,2" />
                                    <TextBox x:Name="NewLessonSubTitle" Margin="0,0,0,8" />
                                    <Button Content="+ Add Lesson"
                                            Style="{DynamicResource NavButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Click="AddLesson_Click" />
                                </StackPanel>
                            </Border>

                            <!-- Shared notes -->
                            <TextBlock Text="Notes (shared for this day)" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,4" />
                            <TextBox x:Name="NotesBox"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="60" Margin="0,0,0,10" />

                            <!-- Mark all complete -->
                            <CheckBox x:Name="CompleteCheck"
                                      Content="Mark entire block as complete"
                                      Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ============================================================ -->
                <!-- RESOURCES -->
                <!-- ============================================================ -->
                <Expander Header="Resources" IsExpanded="False"
                          Margin="0,0,0,8"
                          Foreground="{DynamicResource TextPrimaryBrush}">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="5" Padding="14,10">
                        <StackPanel>
                            <ListBox x:Name="ResourceListBox" MaxHeight="140"
                                     BorderBrush="{DynamicResource BorderBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Path}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock x:Name="NoResourcesLabel"
                                       Text="No resources linked to this subject yet."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,4,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Open" Style="{DynamicResource PrimaryButtonStyle}"
                                        Margin="0,0,8,0" Click="OpenResource_Click" />
                                <Button Content="Manage Resources"
                                        Style="{DynamicResource NavButtonStyle}"
                                        Click="ManageResources_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom buttons -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="DeleteBtn" Content="Delete Entry"
                        Grid.Column="0" HorizontalAlignment="Left"
                        Style="{DynamicResource NavButtonStyle}"
                        Foreground="#CC2222" BorderBrush="#CC2222"
                        Click="Delete_Click" Visibility="Collapsed" />
                <Button Content="Cancel" Grid.Column="1"
                        Style="{DynamicResource NavButtonStyle}"
                        Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="Save" Grid.Column="2"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Click="Save_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
