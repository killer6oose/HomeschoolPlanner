<Window x:Class="HomeschoolPlanner.Dialogs.LessonEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Class Details"
        Width="500" Height="560"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: subject + date -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel>
                <TextBlock x:Name="SubjectLabel" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock x:Name="DateLabel" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0" />
            </StackPanel>
        </Border>

        <!-- Expandable sections -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,8">
            <StackPanel>

                <!-- ====================================================== -->
                <!-- LESSONS section -->
                <!-- ====================================================== -->
                <Expander x:Name="LessonsExpander"
                          Header="Lessons"
                          IsExpanded="True"
                          Margin="0,8,0,8"
                          Foreground="{DynamicResource TextPrimaryBrush}">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="5" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Lesson Title" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox x:Name="TitleBox" Margin="0,0,0,12" />

                            <TextBlock Text="Notes" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                            <TextBox x:Name="NotesBox"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="80"
                                     Margin="0,0,0,12" />

                            <CheckBox x:Name="CompleteCheck"
                                      Content="Mark as complete"
                                      Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- ====================================================== -->
                <!-- RESOURCES section -->
                <!-- ====================================================== -->
                <Expander x:Name="ResourcesExpander"
                          Header="Resources"
                          IsExpanded="False"
                          Margin="0,0,0,8"
                          Foreground="{DynamicResource TextPrimaryBrush}">
                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="5" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="Files and links attached to this class."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,8" />
                            <ListBox x:Name="ResourceListBox"
                                     MaxHeight="160"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     SelectionChanged="ResourceListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Type}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock x:Name="NoResourcesLabel"
                                       Text="No resources linked to this class yet."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,4,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Open" Style="{DynamicResource PrimaryButtonStyle}"
                                        Margin="0,0,8,0" Click="OpenResource_Click" />
                                <Button Content="Manage Resources"
                                        Style="{DynamicResource NavButtonStyle}"
                                        Click="ManageResources_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom action buttons -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="DeleteBtn"
                        Content="Delete Lesson"
                        Grid.Column="0"
                        HorizontalAlignment="Left"
                        Style="{DynamicResource NavButtonStyle}"
                        Foreground="#CC2222" BorderBrush="#CC2222"
                        Click="Delete_Click"
                        Visibility="Collapsed" />
                <Button Content="Cancel"
                        Grid.Column="1"
                        Style="{DynamicResource NavButtonStyle}"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button Content="Save"
                        Grid.Column="2"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Click="Save_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
