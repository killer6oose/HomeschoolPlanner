<Window x:Class="HomeschoolPlanner.Dialogs.SelectStudentsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split View - Select Students"
        Width="360" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Split View" FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
        <TextBlock Grid.Row="1" Text="Select 2 or more students to view side by side."
                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,14" />

        <StackPanel x:Name="CheckboxPanel" Grid.Row="2" Margin="0,0,0,16" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource NavButtonStyle}"
                    Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Apply" Style="{StaticResource PrimaryButtonStyle}"
                    Click="Apply_Click" />
        </StackPanel>
    </Grid>
</Window>
