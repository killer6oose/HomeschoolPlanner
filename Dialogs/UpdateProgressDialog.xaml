<Window x:Class="HomeschoolPlanner.Dialogs.UpdateProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Updating Homeschool Planner"
        Width="380" Height="140"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="{DynamicResource DialogBackgroundBrush}">

    <StackPanel Margin="24,20,24,20" VerticalAlignment="Center">

        <TextBlock x:Name="StatusText"
                   Text="Downloading update..."
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,12" />

        <ProgressBar x:Name="ProgressBar"
                     Minimum="0" Maximum="100" Value="0"
                     Height="10"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource AccentBrush}" />

        <TextBlock x:Name="PercentText"
                   Text="0%"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Right"
                   Margin="0,4,0,0" />

    </StackPanel>
</Window>
