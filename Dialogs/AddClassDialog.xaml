<Window x:Class="HomeschoolPlanner.Dialogs.AddClassDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Class"
        Width="500" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Add a Class" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16" />

        <!-- Subject: pick existing or create new -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="Subject" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
            <ComboBox x:Name="SubjectCombo" SelectionChanged="SubjectCombo_SelectionChanged" />
            <!-- New subject fields shown when "New subject..." is selected -->
            <StackPanel x:Name="NewSubjectPanel" Visibility="Collapsed" Margin="0,8,0,0">
                <TextBlock Text="Subject Name" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox x:Name="NewSubjectName" Margin="0,0,0,8" />
                <TextBlock Text="Color (hex, e.g. #E53935)" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewSubjectColor" Text="#4A7CB5"
                             TextChanged="ColorBox_TextChanged" />
                    <Border x:Name="ColorPreview" Grid.Column="1"
                            Width="36" Height="28" CornerRadius="4"
                            Margin="8,0,0,0" Background="#4A7CB5" />
                </Grid>
                <WrapPanel x:Name="ColorSwatches" Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Schedule type -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="When should this class appear?" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />
            <RadioButton x:Name="RadioEveryDay"   Content="Every school day"
                         IsChecked="True" Margin="0,0,0,6"
                         Checked="ScheduleType_Changed" />
            <RadioButton x:Name="RadioDaysOfWeek" Content="Specific days of the week"
                         Margin="0,0,0,6"
                         Checked="ScheduleType_Changed" />
            <RadioButton x:Name="RadioSpecific"   Content="Specific date(s) only"
                         Checked="ScheduleType_Changed" />
        </StackPanel>

        <!-- Days of week checkboxes -->
        <StackPanel x:Name="DaysOfWeekPanel" Grid.Row="3" Orientation="Horizontal"
                    Visibility="Collapsed" Margin="0,0,0,14">
            <CheckBox x:Name="ChkMon" Content="Mon" Margin="0,0,12,0" IsChecked="True" />
            <CheckBox x:Name="ChkTue" Content="Tue" Margin="0,0,12,0" IsChecked="True" />
            <CheckBox x:Name="ChkWed" Content="Wed" Margin="0,0,12,0" IsChecked="True" />
            <CheckBox x:Name="ChkThu" Content="Thu" Margin="0,0,12,0" IsChecked="True" />
            <CheckBox x:Name="ChkFri" Content="Fri" Margin="0,0,12,0" IsChecked="True" />
            <CheckBox x:Name="ChkSat" Content="Sat" Margin="0,0,12,0" />
            <CheckBox x:Name="ChkSun" Content="Sun" />
        </StackPanel>

        <!-- Specific dates picker -->
        <StackPanel x:Name="SpecificDatesPanel" Grid.Row="4" Visibility="Collapsed" Margin="0,0,0,14">
            <TextBlock Text="Pick dates to add this class:" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <DatePicker x:Name="DatePickerInput" Width="180" />
                <Button Content="+ Add" Style="{DynamicResource NavButtonStyle}"
                        Margin="8,0,0,0" Click="AddDate_Click" />
            </StackPanel>
            <ListBox x:Name="SelectedDatesList"
                     MaxHeight="100"
                     BorderBrush="{DynamicResource BorderBrush}" />
            <Button Content="Remove selected" Style="{DynamicResource NavButtonStyle}"
                    HorizontalAlignment="Left" Margin="0,4,0,0"
                    Click="RemoveDate_Click" />
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="Cancel" Grid.Column="1"
                    Style="{DynamicResource NavButtonStyle}"
                    Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button Content="Add Class" Grid.Column="2"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Click="Save_Click" />
        </Grid>
    </Grid>
</Window>
