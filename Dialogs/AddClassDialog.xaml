<Window x:Class="HomeschoolPlanner.Dialogs.AddClassDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Subject"
        Width="500" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource DialogBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Add a Subject" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16" />

        <!-- Subject picker -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="Subject" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
            <ComboBox x:Name="SubjectCombo" SelectionChanged="SubjectCombo_SelectionChanged" />
            <StackPanel x:Name="NewSubjectPanel" Visibility="Collapsed" Margin="0,8,0,0">
                <TextBlock Text="Subject Name" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <TextBox x:Name="NewSubjectName" Margin="0,0,0,8" />
                <TextBlock Text="Color (hex)" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewSubjectColor" Text="#4A7CB5" TextChanged="ColorBox_TextChanged" />
                    <Border x:Name="ColorPreview" Grid.Column="1"
                            Width="36" Height="28" CornerRadius="4"
                            Margin="8,0,0,0" Background="#4A7CB5" />
                </Grid>
                <WrapPanel x:Name="ColorSwatches" Margin="0,4,0,0" />
            </StackPanel>
        </StackPanel>

        <!-- Schedule type -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="When does this subject appear?" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />
            <RadioButton x:Name="RadioEveryDay"   Content="Every school day (Mon-Fri)"
                         IsChecked="True" Margin="0,0,0,6" Checked="ScheduleType_Changed" />
            <RadioButton x:Name="RadioDaysOfWeek" Content="Specific days of the week"
                         Margin="0,0,0,6" Checked="ScheduleType_Changed" />
            <RadioButton x:Name="RadioMonthly"    Content="Monthly (first/last day of month)"
                         Margin="0,0,0,6" Checked="ScheduleType_Changed" />
            <RadioButton x:Name="RadioSpecific"   Content="Specific date(s) only"
                         Checked="ScheduleType_Changed" />
        </StackPanel>

        <!-- Days of week + repeat-until -->
        <StackPanel x:Name="DaysOfWeekPanel" Grid.Row="3" Visibility="Collapsed" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <CheckBox x:Name="ChkMon" Content="Mon" Margin="0,0,10,0" IsChecked="True" />
                <CheckBox x:Name="ChkTue" Content="Tue" Margin="0,0,10,0" IsChecked="True" />
                <CheckBox x:Name="ChkWed" Content="Wed" Margin="0,0,10,0" IsChecked="True" />
                <CheckBox x:Name="ChkThu" Content="Thu" Margin="0,0,10,0" IsChecked="True" />
                <CheckBox x:Name="ChkFri" Content="Fri" Margin="0,0,10,0" IsChecked="True" />
                <CheckBox x:Name="ChkSat" Content="Sat" Margin="0,0,10,0" />
                <CheckBox x:Name="ChkSun" Content="Sun" />
            </StackPanel>
            <!-- Repeat until -->
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="10,8">
                <StackPanel>
                    <TextBlock Text="Repeat until..." FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />
                    <RadioButton x:Name="RepeatForever" Content="No end date"
                                 GroupName="RepeatEnd" IsChecked="True" Margin="0,0,0,6"
                                 Checked="RepeatEnd_Changed" />
                    <RadioButton x:Name="RepeatByDate" Content="End by date"
                                 GroupName="RepeatEnd" Margin="0,0,0,6"
                                 Checked="RepeatEnd_Changed" />
                    <DatePicker x:Name="RepeatEndDatePicker" Visibility="Collapsed"
                                Width="200" HorizontalAlignment="Left" Margin="16,0,0,8" />
                    <RadioButton x:Name="RepeatByCount" Content="After X occurrences"
                                 GroupName="RepeatEnd"
                                 Checked="RepeatEnd_Changed" />
                    <StackPanel Orientation="Horizontal" x:Name="RepeatCountPanel"
                                Visibility="Collapsed" Margin="16,4,0,0">
                        <TextBox x:Name="RepeatCountBox" Width="60" Text="7" />
                        <TextBlock Text=" times" VerticalAlignment="Center" Margin="4,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Monthly options -->
        <StackPanel x:Name="MonthlyPanel" Grid.Row="4" Visibility="Collapsed" Margin="0,0,0,14">
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="10,8">
                <StackPanel>
                    <TextBlock Text="Monthly pattern" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />
                    <RadioButton x:Name="MonthlyFirstDay" Content="First..." GroupName="MonthlyPat"
                                 IsChecked="True" Margin="0,0,0,4" Checked="Monthly_Changed" />
                    <RadioButton x:Name="MonthlyLastDay"  Content="Last..."  GroupName="MonthlyPat"
                                 Margin="0,0,0,4" Checked="Monthly_Changed" />
                    <RadioButton x:Name="MonthlyDayNum"   Content="Day of month:"
                                 GroupName="MonthlyPat" Margin="0,0,0,4" Checked="Monthly_Changed" />
                    <!-- Day-of-month selector -->
                    <StackPanel Orientation="Horizontal" x:Name="MonthlyDayNumPanel"
                                Visibility="Collapsed" Margin="16,0,0,6">
                        <TextBox x:Name="MonthlyDayNumBox" Width="50" Text="1" />
                        <TextBlock Text=" (1-28)" VerticalAlignment="Center" Margin="4,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                    </StackPanel>
                    <!-- Weekday selector for First/Last -->
                    <StackPanel Orientation="Horizontal" x:Name="MonthlyWeekdayPanel" Margin="16,0,0,0">
                        <TextBlock Text="Weekday: " VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                        <ComboBox x:Name="MonthlyWeekdayCombo" Width="100">
                            <ComboBoxItem Content="Monday"    Tag="Mon" IsSelected="True" />
                            <ComboBoxItem Content="Tuesday"   Tag="Tue" />
                            <ComboBoxItem Content="Wednesday" Tag="Wed" />
                            <ComboBoxItem Content="Thursday"  Tag="Thu" />
                            <ComboBoxItem Content="Friday"    Tag="Fri" />
                            <ComboBoxItem Content="Saturday"  Tag="Sat" />
                            <ComboBoxItem Content="Sunday"    Tag="Sun" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Specific dates -->
        <StackPanel x:Name="SpecificDatesPanel" Grid.Row="5" Visibility="Visible" Margin="0,0,0,14">
            <TextBlock Text="Pick dates:" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <DatePicker x:Name="DatePickerInput" Width="180" />
                <Button Content="+ Add" Style="{DynamicResource NavButtonStyle}"
                        Margin="8,0,0,0" Click="AddDate_Click" />
            </StackPanel>
            <ListBox x:Name="SelectedDatesList" MaxHeight="100"
                     BorderBrush="{DynamicResource BorderBrush}" />
            <Button Content="Remove selected" Style="{DynamicResource NavButtonStyle}"
                    HorizontalAlignment="Left" Margin="0,4,0,0" Click="RemoveDate_Click" />
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="Cancel" Grid.Column="1"
                    Style="{DynamicResource NavButtonStyle}"
                    Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="Add Subject" Grid.Column="2"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Click="Save_Click" />
        </Grid>
    </Grid>
    </ScrollViewer>
</Window>
