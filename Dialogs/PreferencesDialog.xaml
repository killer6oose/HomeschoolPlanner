<Window x:Class="HomeschoolPlanner.Dialogs.PreferencesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preferences"
        Width="540" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource DialogBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20,16,20,4">
            <StackPanel>

                <!-- THEME -->
                <TextBlock Text="Planner Theme" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" />

                <WrapPanel Margin="0,0,0,10">
                    <RadioButton x:Name="RadioLight"     Content="Light"      GroupName="Theme" IsChecked="True"
                                 Checked="Theme_Changed" Margin="0,0,16,6" />
                    <RadioButton x:Name="RadioDark"      Content="Dark"       GroupName="Theme"
                                 Checked="Theme_Changed" Margin="0,0,16,6" />
                    <RadioButton x:Name="RadioPride"     Content="Pride"      GroupName="Theme"
                                 Checked="Theme_Changed" Margin="0,0,16,6" />
                    <RadioButton x:Name="RadioPrideDark" Content="Pride Dark" GroupName="Theme"
                                 Checked="Theme_Changed" Margin="0,0,16,6" />
                    <RadioButton x:Name="RadioCherry"    Content="Cherry"     GroupName="Theme"
                                 Checked="Theme_Changed" Margin="0,0,16,6" />
                    <RadioButton x:Name="RadioCustom"    Content="Custom"     GroupName="Theme"
                                 Checked="Theme_Changed" Margin="0,0,0,6" />
                </WrapPanel>

                <!-- Custom color pickers - visible only when Custom is selected -->
                <Border x:Name="CustomSection" Visibility="Collapsed"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="6" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Custom Colors" FontWeight="SemiBold" Margin="0,0,0,10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />

                        <!-- Primary (accent) color -->
                        <TextBlock Text="Primary (accent)" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CustomPrimaryBox" Text="#4A7CB5"
                                     TextChanged="CustomColor_TextChanged" Tag="Primary" />
                            <Border x:Name="CustomPrimaryPreview" Grid.Column="1"
                                    Width="36" Height="28" CornerRadius="4"
                                    Margin="8,0,0,0" Background="#4A7CB5" />
                        </Grid>
                        <WrapPanel x:Name="CustomPrimarySwatches" Margin="0,0,0,12" />

                        <!-- Background color -->
                        <TextBlock Text="Background" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CustomBgBox" Text="#F5F6FA"
                                     TextChanged="CustomColor_TextChanged" Tag="Background" />
                            <Border x:Name="CustomBgPreview" Grid.Column="1"
                                    Width="36" Height="28" CornerRadius="4"
                                    Margin="8,0,0,0" Background="#F5F6FA" />
                        </Grid>
                        <WrapPanel x:Name="CustomBgSwatches" Margin="0,0,0,12" />

                        <!-- Font color -->
                        <TextBlock Text="Font Color" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CustomFontBox" Text="#1C2333"
                                     TextChanged="CustomColor_TextChanged" Tag="Font" />
                            <Border x:Name="CustomFontPreview" Grid.Column="1"
                                    Width="36" Height="28" CornerRadius="4"
                                    Margin="8,0,0,0" Background="#1C2333" />
                        </Grid>
                        <WrapPanel x:Name="CustomFontSwatches" />
                    </StackPanel>
                </Border>

                <Separator Margin="0,4,0,16" />

                <!-- FONT SIZE -->
                <TextBlock Text="Font Size" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton x:Name="RadioSmall"  Content="Small"  GroupName="FontSize" Margin="0,0,16,0" />
                    <RadioButton x:Name="RadioMedium" Content="Medium" GroupName="FontSize" IsChecked="True" Margin="0,0,16,0" />
                    <RadioButton x:Name="RadioLarge"  Content="Large"  GroupName="FontSize" />
                </StackPanel>

                <Separator Margin="0,4,0,16" />

                <!-- FONT FAMILY -->
                <TextBlock Text="Font" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" />
                <ComboBox x:Name="FontCombo" Width="260" HorizontalAlignment="Left"
                          Margin="0,0,0,16" SelectionChanged="Font_Changed" />

                <Separator Margin="0,4,0,16" />

                <!-- WEEK VIEW -->
                <TextBlock Text="Week View" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4" VerticalAlignment="Center">
                    <TextBlock Text="First day of week:" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,10,0" />
                    <ComboBox x:Name="WeekStartCombo" Width="160" />
                </StackPanel>
                <TextBlock x:Name="WeekStartHint"
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,4,0,16" />

                <Separator Margin="0,4,0,16" />

                <!-- BEHAVIOR -->
                <TextBlock Text="Behavior" FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10" />
                <CheckBox x:Name="ShowGradeTemplateCheck"
                          Content="Ask about default subjects when creating a student in a grade"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          Margin="0,0,0,6" />
                <TextBlock Text="When checked, adding a student to a grade that has a template will prompt to load those default subjects."
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="22,0,0,16" />

                <Separator Margin="0,4,0,16" />

                <!-- DANGER ZONE -->
                <TextBlock Text="Danger Zone" FontSize="15" FontWeight="Bold"
                           Foreground="#CC2222" Margin="0,0,0,10" />
                <Border Background="{DynamicResource DangerSurfaceBrush}"
                        BorderBrush="{DynamicResource DangerBorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Text="Delete All Data"
                                   FontWeight="SemiBold" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Permanently removes all students, subjects, and lesson history. Cannot be reversed."
                                   TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,10" />
                        <Button Content="Delete All Data"
                                Style="{StaticResource NavButtonStyle}"
                                Foreground="#CC2222" BorderBrush="#CC2222"
                                HorizontalAlignment="Left"
                                Click="DeleteAllData_Click" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Bottom buttons -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12" Background="{DynamicResource SurfaceBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource NavButtonStyle}"
                        Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="Apply" Style="{StaticResource PrimaryButtonStyle}"
                        Click="Apply_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
