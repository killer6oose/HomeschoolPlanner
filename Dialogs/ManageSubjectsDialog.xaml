<Window x:Class="HomeschoolPlanner.Dialogs.ManageSubjectsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Subjects"
        Width="540" Height="580"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogBackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="18" FontWeight="Bold"
                   x:Name="DialogTitle"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16" />

        <!-- Template preview - shown only when the student has no subjects yet -->
        <Border x:Name="TemplatePreviewPanel"
                Grid.Row="1"
                Visibility="Collapsed"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TemplatePreviewTitle"
                               Text="Default subjects for this grade"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="DismissTemplateLink"
                               Grid.Column="1"
                               Text="I'll make my own"
                               FontSize="12"
                               Foreground="{DynamicResource AccentBrush}"
                               Cursor="Hand"
                               VerticalAlignment="Center"
                               MouseLeftButtonUp="DismissTemplate_Click" />
                </Grid>
                <WrapPanel x:Name="TemplatePreviewList" Margin="0,0,0,10" />
                <Button x:Name="UseDefaultsBtn"
                        Content="Add these defaults"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        HorizontalAlignment="Left"
                        Click="UseDefaults_Click" />
            </StackPanel>
        </Border>

        <!-- Subject list -->
        <ListBox x:Name="SubjectList" Grid.Row="2"
                 BorderBrush="{DynamicResource BorderBrush}"
                 SelectionChanged="SubjectList_SelectionChanged"
                 Margin="0,0,0,12" />

        <!-- Edit form -->
        <Border Grid.Row="3"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14">
            <StackPanel>
                <TextBlock x:Name="FormTitle" Text="Add Subject" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Subject Name" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="NameBox" FontSize="13" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Color" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ColorBox" Text="#4A7CB5" FontSize="13" TextChanged="ColorBox_TextChanged" />
                            <Border x:Name="ColorPreview" Grid.Column="1"
                                    Width="36" Height="28" CornerRadius="4"
                                    Margin="6,0,0,0" Background="#4A7CB5" />
                        </Grid>
                        <WrapPanel x:Name="ColorSwatches" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Schedule -->
                <TextBlock Text="Schedule" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                <StackPanel Margin="0,0,0,8">
                    <RadioButton x:Name="RadioEveryDay"   Content="Every school day"
                                 IsChecked="True" FontSize="13" Margin="0,0,0,4"
                                 Checked="ScheduleType_Changed" />
                    <RadioButton x:Name="RadioDaysOfWeek" Content="Specific days of the week"
                                 FontSize="13" Margin="0,0,0,4"
                                 Checked="ScheduleType_Changed" />
                    <RadioButton x:Name="RadioSpecific"   Content="Specific dates only"
                                 FontSize="13" Margin="0,0,0,4"
                                 Checked="ScheduleType_Changed" />
                    <RadioButton x:Name="RadioNone"       Content="No automatic schedule"
                                 FontSize="13"
                                 Checked="ScheduleType_Changed" />
                </StackPanel>

                <StackPanel x:Name="DaysOfWeekPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,8">
                    <CheckBox x:Name="ChkMon" Content="Mon" FontSize="13" Margin="0,0,10,0" IsChecked="True" />
                    <CheckBox x:Name="ChkTue" Content="Tue" FontSize="13" Margin="0,0,10,0" IsChecked="True" />
                    <CheckBox x:Name="ChkWed" Content="Wed" FontSize="13" Margin="0,0,10,0" IsChecked="True" />
                    <CheckBox x:Name="ChkThu" Content="Thu" FontSize="13" Margin="0,0,10,0" IsChecked="True" />
                    <CheckBox x:Name="ChkFri" Content="Fri" FontSize="13" Margin="0,0,10,0" IsChecked="True" />
                </StackPanel>

                <StackPanel x:Name="SpecificDatesPanel" Visibility="Collapsed" Margin="0,0,0,8">
                    <TextBlock Text="Dates (YYYY-MM-DD, one per line)" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox x:Name="SpecificDatesBox" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" FontSize="13"
                             FontFamily="Consolas" MinHeight="50" MaxHeight="80" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="DeleteBtn" Content="Delete" Visibility="Collapsed"
                            Style="{DynamicResource NavButtonStyle}" Foreground="#CC2222"
                            Margin="0,0,8,0" Click="Delete_Click" />
                    <Button Content="Clear" Style="{DynamicResource NavButtonStyle}"
                            Margin="0,0,8,0" Click="Clear_Click" />
                    <Button Content="Save" Style="{DynamicResource PrimaryButtonStyle}"
                            Click="Save_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
