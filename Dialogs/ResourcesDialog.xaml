<Window x:Class="HomeschoolPlanner.Dialogs.ResourcesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Resources"
        Width="620" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource DialogBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,12,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <!-- Left: resource list -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Saved Resources"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,8" />

                <ListBox x:Name="ResourceListBox" Grid.Row="1"
                         BorderBrush="{DynamicResource BorderBrush}"
                         SelectionChanged="ResourceListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="4,2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Path}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Linked: {0}">
                                            <Binding Path="SubjectName" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SubjectName}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="Open" Style="{DynamicResource PrimaryButtonStyle}"
                            Margin="0,0,8,0" Click="OpenResource_Click" />
                    <Button Content="Delete" Style="{DynamicResource NavButtonStyle}"
                            Foreground="#CC2222" BorderBrush="#CC2222"
                            Click="DeleteResource_Click" />
                </StackPanel>
            </Grid>

            <!-- Right: add / edit form -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14">
                <StackPanel>
                    <TextBlock x:Name="FormTitle" Text="Add Resource"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12" />

                    <!-- Type -->
                    <TextBlock Text="Type" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="RadioUrl"  Content="URL"  GroupName="ResType"
                                     IsChecked="True" Margin="0,0,12,0"
                                     Checked="ResType_Changed" />
                        <RadioButton x:Name="RadioFile" Content="File" GroupName="ResType"
                                     Checked="ResType_Changed" />
                    </StackPanel>

                    <!-- Name -->
                    <TextBlock Text="Display Name" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox x:Name="NameBox" Margin="0,0,0,10" />

                    <!-- URL / File path -->
                    <TextBlock x:Name="PathLabel" Text="URL" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PathBox" />
                        <Button x:Name="BrowseBtn" Grid.Column="1" Content="..."
                                Style="{DynamicResource NavButtonStyle}"
                                Visibility="Collapsed" Margin="4,0,0,0"
                                Click="Browse_Click" />
                    </Grid>

                    <!-- Description -->
                    <TextBlock Text="Description (optional)" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <TextBox x:Name="DescBox" AcceptsReturn="True" Height="50"
                             TextWrapping="Wrap" Margin="0,0,0,10" />

                    <!-- Linked class -->
                    <TextBlock Text="Link to class (optional)" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <ComboBox x:Name="SubjectCombo" Margin="0,0,0,14" />

                    <Button Content="Save Resource"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Click="SaveResource_Click" />
                    <Button Content="Clear Form"
                            Style="{DynamicResource NavButtonStyle}"
                            Margin="0,6,0,0"
                            Click="ClearForm_Click" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom close button -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,10" Background="{DynamicResource SurfaceBrush}">
            <Button Content="Close" Style="{DynamicResource NavButtonStyle}"
                    HorizontalAlignment="Right" Click="Close_Click" />
        </Border>
    </Grid>
</Window>
