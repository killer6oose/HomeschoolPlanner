<Window x:Class="HomeschoolPlanner.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Homeschool Planner"
        Width="400" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="30,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- App name + icon area -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Homeschool Planner"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Text="A desktop lesson planner for homeschool families."
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- Details -->
        <StackPanel Grid.Row="1">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Author" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock Grid.Column="1" Text="Andrew Hatton"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </Grid>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Source" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock x:Name="RepoLink" Grid.Column="1"
                           Text="github.com/killer6oose/HomeschoolPlan"
                           Foreground="{DynamicResource AccentBrush}"
                           Cursor="Hand"
                           TextDecorations="Underline"
                           MouseLeftButtonDown="RepoLink_Click" />
            </Grid>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Copyright" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock x:Name="CopyrightLabel" Grid.Column="1"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Version" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock x:Name="VersionLabel" Grid.Column="1"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </Grid>
        </StackPanel>

        <!-- Close button -->
        <Button Grid.Row="2"
                Content="Close"
                Style="{DynamicResource PrimaryButtonStyle}"
                HorizontalAlignment="Right"
                Click="Close_Click" />
    </Grid>
</Window>
