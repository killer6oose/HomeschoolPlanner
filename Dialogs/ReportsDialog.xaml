<Window x:Class="HomeschoolPlanner.Dialogs.ReportsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generate Report"
        Width="500" Height="720"
        MinWidth="440" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource DialogBackgroundBrush}"
        Loaded="OnLoaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Mode selector -->
            <RowDefinition Height="Auto" />  <!-- Students label -->
            <RowDefinition Height="80"   />  <!-- Students checklist -->
            <RowDefinition Height="Auto" />  <!-- Subjects label -->
            <RowDefinition Height="Auto" />  <!-- Subjects group hint -->
            <RowDefinition Height="*"    />  <!-- Subjects checklist -->
            <RowDefinition Height="Auto" />  <!-- Grade level panel -->
            <RowDefinition Height="Auto" />  <!-- Date range -->
            <RowDefinition Height="Auto" />  <!-- Report type -->
            <RowDefinition Height="Auto" />  <!-- Export format -->
            <RowDefinition Height="Auto" />  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- Report mode selector -->
        <!-- ============================================================ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Report For"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ModeStudentsRadio"
                             Content="Students"
                             GroupName="ReportMode"
                             IsChecked="True"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Margin="0,0,20,0"
                             Checked="ReportMode_Changed" />
                <RadioButton x:Name="ModeGradeRadio"
                             Content="Grade Level (subject roster)"
                             GroupName="ReportMode"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Checked="ReportMode_Changed" />
            </StackPanel>
        </StackPanel>

        <!-- ============================================================ -->
        <!-- STUDENTS MODE: students label + select-all -->
        <!-- ============================================================ -->
        <Grid x:Name="StudentsLabelRow" Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Students"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="SelectAllStudentsLink"
                       Grid.Column="1"
                       Text="Select all"
                       Foreground="{DynamicResource AccentBrush}"
                       Cursor="Hand"
                       VerticalAlignment="Center"
                       MouseLeftButtonUp="SelectAllStudentsLink_Click" />
        </Grid>

        <!-- ============================================================ -->
        <!-- STUDENTS MODE: students checklist -->
        <!-- ============================================================ -->
        <Border x:Name="StudentsBorder"
                Grid.Row="2"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,14">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <WrapPanel x:Name="StudentPanel" Orientation="Horizontal" />
            </ScrollViewer>
        </Border>

        <!-- ============================================================ -->
        <!-- STUDENTS MODE: subjects label + select-all -->
        <!-- ============================================================ -->
        <Grid x:Name="SubjectsLabelRow" Grid.Row="3" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Subjects"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="SelectAllSubjectsLink"
                       Grid.Column="1"
                       Text="Select all"
                       Foreground="{DynamicResource AccentBrush}"
                       Cursor="Hand"
                       VerticalAlignment="Center"
                       MouseLeftButtonUp="SelectAllSubjectsLink_Click" />
        </Grid>

        <!-- ============================================================ -->
        <!-- STUDENTS MODE: subjects group hint -->
        <!-- ============================================================ -->
        <TextBlock x:Name="SubjectGroupHint"
                   Grid.Row="4"
                   Visibility="Collapsed"
                   FontSize="10"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,4"
                   Text="Subjects grouped by student" />

        <!-- ============================================================ -->
        <!-- STUDENTS MODE: subjects checklist -->
        <!-- ============================================================ -->
        <Border x:Name="SubjectsBorder"
                Grid.Row="5"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,14">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <StackPanel x:Name="SubjectPanel" />
            </ScrollViewer>
        </Border>

        <!-- ============================================================ -->
        <!-- GRADE LEVEL MODE: grade picker panel -->
        <!-- ============================================================ -->
        <StackPanel x:Name="GradeLevelPanel"
                    Grid.Row="6"
                    Visibility="Collapsed"
                    Margin="0,0,0,14">
            <TextBlock Text="Grade Level"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,6" />
            <ComboBox x:Name="GradeLevelCombo" Width="200" HorizontalAlignment="Left" />
            <TextBlock Text="Exports a CSV listing every subject for all students in this grade."
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- ============================================================ -->
        <!-- STUDENTS MODE: Date range -->
        <!-- ============================================================ -->
        <StackPanel x:Name="DateRangePanel" Grid.Row="7" Margin="0,0,0,14">
            <TextBlock Text="Date Range"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal">
                <DatePicker x:Name="StartPicker" Width="160" />
                <TextBlock Text="to" Margin="10,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <DatePicker x:Name="EndPicker" Width="160" />
            </StackPanel>
        </StackPanel>

        <!-- ============================================================ -->
        <!-- STUDENTS MODE: Report type -->
        <!-- ============================================================ -->
        <StackPanel x:Name="ReportTypePanel" Grid.Row="8" Margin="0,0,0,14">
            <TextBlock Text="Report Type"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="SummaryRadio"
                             Content="Subject Summary"
                             GroupName="ReportType"
                             IsChecked="True"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Margin="0,0,20,0" />
                <RadioButton x:Name="LogRadio"
                             Content="Daily Log"
                             GroupName="ReportType"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- ============================================================ -->
        <!-- STUDENTS MODE: Export format -->
        <!-- ============================================================ -->
        <StackPanel x:Name="FormatPanel" Grid.Row="9" Margin="0,0,0,20">
            <TextBlock Text="Export Format"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="PdfRadio"
                             Content="PDF"
                             GroupName="Format"
                             IsChecked="True"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Margin="0,0,20,0" />
                <RadioButton x:Name="CsvRadio"
                             Content="CSV"
                             GroupName="Format"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- ============================================================ -->
        <!-- Buttons -->
        <!-- ============================================================ -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{DynamicResource NavButtonStyle}"
                    Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button x:Name="GenerateBtn"
                    Content="Generate Report"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Click="Generate_Click" />
        </StackPanel>

    </Grid>
</Window>
