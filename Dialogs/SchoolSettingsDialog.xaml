<Window x:Class="HomeschoolPlanner.Dialogs.SchoolSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="School Settings"
        Width="580" Height="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="16,12,16,4"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}">

            <!-- ============================================================ -->
            <!-- TAB 1: General -->
            <!-- ============================================================ -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>

                        <!-- School Year Start -->
                        <TextBlock Text="School Year Start"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,8" />
                        <DatePicker x:Name="SchoolYearStartPicker"
                                    Width="200" HorizontalAlignment="Left"
                                    Margin="0,0,0,20" />

                        <Separator Margin="0,4,0,16" />

                        <!-- School Days -->
                        <TextBlock Text="School Days"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="Choose which days appear as columns in the week view."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,0,0,12" />

                        <CheckBox x:Name="ChkMon" Content="Monday"    Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkTue" Content="Tuesday"   Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkWed" Content="Wednesday" Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkThu" Content="Thursday"  Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkFri" Content="Friday"    Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkSat" Content="Saturday"  Margin="0,0,0,6" />
                        <CheckBox x:Name="ChkSun" Content="Sunday"    Margin="0,0,0,6" />

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================================ -->
            <!-- TAB 2: Class Library -->
            <!-- ============================================================ -->
            <TabItem Header="Class Library">
                <Grid Margin="16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Grade selector -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Grade:" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <ComboBox x:Name="GradeCombo" Width="180"
                                  SelectionChanged="GradeCombo_SelectionChanged" />
                    </StackPanel>

                    <!-- Template toggle -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="5" Padding="10,8"
                            Margin="0,0,0,12">
                        <CheckBox x:Name="ChkTemplate"
                                  Content="Use as default template for this grade (auto-loads when a student of this grade is created)"
                                  TextWrapping="Wrap" />
                    </Border>

                    <!-- Class list -->
                    <ListBox x:Name="ClassListBox" Grid.Row="2"
                             BorderBrush="{DynamicResource BorderBrush}"
                             SelectionChanged="ClassListBox_SelectionChanged" />

                    <!-- Edit panel below list -->
                    <Border Grid.Row="3"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="12" Margin="0,10,0,0">
                        <StackPanel>

                            <TextBlock x:Name="EditPanelTitle" Text="New Class"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,8" />

                            <!-- Name -->
                            <TextBlock Text="Name" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,2" />
                            <TextBox x:Name="ClassNameBox" Margin="0,0,0,8" />

                            <!-- Color -->
                            <TextBlock Text="Color (hex)" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,2" />
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ClassColorBox" Text="#4A7CB5"
                                         TextChanged="ClassColor_TextChanged" />
                                <Border x:Name="ClassColorPreview" Grid.Column="1"
                                        Width="36" Height="28" CornerRadius="4"
                                        Margin="8,0,0,0" Background="#4A7CB5" />
                            </Grid>
                            <WrapPanel x:Name="ClassColorSwatches" Margin="0,0,0,8" />

                            <!-- Schedule type for template -->
                            <TextBlock Text="Template schedule" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,4" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <RadioButton x:Name="RadioEveryDay"  Content="Every day"  GroupName="TplSched" IsChecked="True" Margin="0,0,12,0"
                                         Checked="ScheduleType_Changed" />
                                <RadioButton x:Name="RadioDaysOfWeek" Content="Specific days" GroupName="TplSched"
                                             Checked="ScheduleType_Changed" Unchecked="ScheduleType_Changed" />
                            </StackPanel>
                            <StackPanel x:Name="DayCheckPanel" Orientation="Horizontal"
                                        Visibility="Collapsed" Margin="0,0,0,8">
                                <CheckBox x:Name="TplMon" Content="Mon" Margin="0,0,8,0" />
                                <CheckBox x:Name="TplTue" Content="Tue" Margin="0,0,8,0" />
                                <CheckBox x:Name="TplWed" Content="Wed" Margin="0,0,8,0" />
                                <CheckBox x:Name="TplThu" Content="Thu" Margin="0,0,8,0" />
                                <CheckBox x:Name="TplFri" Content="Fri" Margin="0,0,8,0" />
                                <CheckBox x:Name="TplSat" Content="Sat" Margin="0,0,8,0" />
                                <CheckBox x:Name="TplSun" Content="Sun" />
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button x:Name="SaveClassBtn" Content="Save"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,0,8,0" Click="SaveClass_Click" />
                                <Button x:Name="DeleteClassBtn" Content="Delete"
                                        Style="{StaticResource NavButtonStyle}"
                                        Foreground="#CC2222" BorderBrush="#CC2222"
                                        Visibility="Collapsed"
                                        Click="DeleteClass_Click" />
                                <Button Content="Clear"
                                        Style="{StaticResource NavButtonStyle}"
                                        Margin="8,0,0,0"
                                        Click="ClearEdit_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Bottom buttons -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12" Background="{DynamicResource SurfaceBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource NavButtonStyle}"
                        Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                        Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
