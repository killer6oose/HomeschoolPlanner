<Window x:Class="HomeschoolPlanner.Dialogs.WelcomeStartupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogBackgroundBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Large action tile button -->
        <Style x:Key="ActionTileStyle" TargetType="Button">
            <Setter Property="Background"              Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush"             Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness"         Value="1" />
            <Setter Property="Cursor"                  Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding"                 Value="16,14" />
            <Setter Property="Margin"                  Value="0,0,0,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="28,28,28,24">

        <!-- Header -->
        <TextBlock Text="Welcome to Homeschool Planner!"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,6" />
        <TextBlock Text="Get started by choosing an option below, or close this window to go straight to the planner."
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,22" />

        <!-- Action: Add a student -->
        <Button Style="{StaticResource ActionTileStyle}" Click="AddStudent_Click">
            <StackPanel>
                <TextBlock x:Name="AddStudentTitle"
                           Text="Add your first student (or more!)"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,3" />
                <TextBlock Text="Create a student profile and assign a color for the calendar."
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <!-- Action: Add / manage subjects -->
        <Button Style="{StaticResource ActionTileStyle}" Click="AddSubject_Click">
            <StackPanel>
                <TextBlock Text="Add your first subject (or modify existing)"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,3" />
                <TextBlock Text="Set up subjects with names, colors, and which days they appear."
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <!-- Action: Take the tour -->
        <Button Style="{StaticResource ActionTileStyle}" Click="TakeTour_Click">
            <StackPanel>
                <TextBlock Text="Take a Tour"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,3" />
                <TextBlock Text="A quick walkthrough of the key features - takes about 30 seconds."
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Button>

        <!-- Dismiss -->
        <Button Content="Close"
                Style="{DynamicResource NavButtonStyle}"
                HorizontalAlignment="Right"
                Margin="0,4,0,0"
                Padding="20,6"
                Click="Close_Click" />

    </StackPanel>
</Window>
