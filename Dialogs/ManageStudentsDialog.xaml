<Window x:Class="HomeschoolPlanner.Dialogs.ManageStudentsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Students"
        Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource DialogBackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Students" FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16" />

        <!-- Student list -->
        <ListBox x:Name="StudentList" Grid.Row="1"
                 BorderBrush="{DynamicResource BorderBrush}"
                 SelectionChanged="StudentList_SelectionChanged"
                 Margin="0,0,0,12" />

        <!-- Edit form -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14">
            <StackPanel>
                <TextBlock x:Name="FormTitle" Text="Add Student" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Name" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="NameBox" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Grade" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <ComboBox x:Name="GradeCombo" SelectionChanged="GradeCombo_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="School Year" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                        <TextBox x:Name="SchoolYearBox" />
                    </StackPanel>
                </Grid>
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Accent Color (hex)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ColorBox" Text="#4A7CB5" TextChanged="ColorBox_TextChanged" />
                        <Border x:Name="ColorPreview" Grid.Column="1"
                                Width="36" Height="28" CornerRadius="4"
                                Margin="8,0,0,0" Background="#4A7CB5" />
                    </Grid>
                    <WrapPanel x:Name="ColorSwatches" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="DeleteBtn" Content="Delete" Visibility="Collapsed"
                            Style="{DynamicResource NavButtonStyle}" Foreground="#CC2222"
                            Margin="0,0,8,0" Click="Delete_Click" />
                    <Button Content="Clear"
                            Style="{DynamicResource NavButtonStyle}"
                            Margin="0,0,8,0" Click="Clear_Click" />
                    <Button Content="Save"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Click="Save_Click" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
