<Window x:Class="HomeschoolPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Homeschool Planner"
        Height="880" Width="1200"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}" Icon="/installer-icon.bmp">

    <DockPanel>

        <!-- ============================================================ -->
        <!-- Menu bar -->
        <!-- ============================================================ -->
        <Menu x:Name="MainMenu"
              DockPanel.Dock="Top"
              Background="{DynamicResource SurfaceBrush}"
              Foreground="{DynamicResource TextPrimaryBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="0,0,0,1">

            <MenuItem Header="File" Foreground="{DynamicResource TextPrimaryBrush}" Click="MenuItem_Click" Cursor="Hand">
                <MenuItem Header="Preferences" Click="Preferences_Click" BorderThickness="1,1,1,1" Cursor="Hand">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Take a Tour" Click="TakeTour_Click" BorderThickness="1,1,1,1" Cursor="Hand">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Open Logs Folder" Click="OpenLogsFolder_Click" BorderThickness="1,1,1,1" Cursor="Hand">
                    <MenuItem.Icon>
                        <TextBlock Text="&#x1F4C2;" FontSize="12" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="About" Click="About_Click" BorderThickness="1,1,1,1" Cursor="Hand">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Foreground="{DynamicResource TextPrimaryBrush}" Click="SchoolSettings_Click" Padding="10,6,0,6" Cursor="Hand">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center">
                            <Canvas Width="511" Height="511">
                                <Path Fill="{DynamicResource TextPrimaryBrush}"
                                      Data="{StaticResource SchoolIconGeometry}" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="School Settings" VerticalAlignment="Center" />
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Foreground="{DynamicResource TextPrimaryBrush}" Click="Resources_Click" Padding="0,6,0,6" Cursor="Hand">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center">
                            <Canvas Width="48" Height="48">
                                <Path Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="1.5"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Data="{StaticResource ResourcesIconGeometry}" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Resources" VerticalAlignment="Center" />
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Foreground="{DynamicResource TextPrimaryBrush}" Click="Reports_Click" Padding="0,6,0,6" Cursor="Hand">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center">
                            <Canvas Width="32" Height="32">
                                <Path Fill="{DynamicResource TextPrimaryBrush}"
                                      Data="{StaticResource ReportsIconGeometry}" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Reports" VerticalAlignment="Center" />
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Foreground="{DynamicResource TextPrimaryBrush}" Click="Help_Click" Padding="0,6,0,6" Cursor="Hand">
                <MenuItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Fill="{DynamicResource TextPrimaryBrush}"
                                      Data="{StaticResource HelpIconGeometry}" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Help" VerticalAlignment="Center" />
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

        </Menu>

        <!-- ============================================================ -->
        <!-- Row 1: Student selector + management buttons -->
        <!-- ============================================================ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Single-student mode -->
                <StackPanel x:Name="SingleStudentPanel" Orientation="Horizontal">
                    <TextBlock Text="Student:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <ComboBox x:Name="StudentCombo"
                              Width="150"
                              DisplayMemberPath="Name"
                              SelectionChanged="StudentCombo_SelectionChanged" />
                </StackPanel>

                <!-- Split-view mode label -->
                <StackPanel x:Name="SplitViewPanel" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="Viewing:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock x:Name="SplitStudentLabel"
                               VerticalAlignment="Center" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>

                <Button x:Name="SplitViewBtn" Content="Split View"
                        Style="{DynamicResource NavButtonStyle}"
                        Margin="8,0,0,0"
                        ToolTip="View multiple students side by side"
                        Click="SplitView_Click" />

                <Button x:Name="StudentsBtn"
                        Content="Students"
                        Style="{DynamicResource NavButtonStyle}"
                        Margin="6,0,0,0"
                        Click="ManageStudents_Click" />

                <Button x:Name="SubjectsBtn"
                        Content="Subjects"
                        Style="{DynamicResource NavButtonStyle}"
                        Margin="6,0,0,0"
                        Click="ManageSubjects_Click" />

            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- Row 2: Date navigation + view toggles -->
        <!-- ============================================================ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,5">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                <Button Style="{DynamicResource NavButtonStyle}" Width="35" Click="PrevPeriod_Click">
                    <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                </Button>

                <Button Content="Today"
                        Style="{DynamicResource NavButtonStyle}"
                        Margin="6,0"
                        Click="Today_Click" />

                <Button Style="{DynamicResource NavButtonStyle}" Width="35" Click="NextPeriod_Click">
                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                </Button>

                <TextBlock x:Name="PeriodLabel"
                           VerticalAlignment="Center"
                           FontSize="{DynamicResource AppFontSize}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="8,0"
                           MinWidth="200"
                           TextAlignment="Center"
                           Width="200" />

                <Button x:Name="DayViewBtn"
                        Content="Day"
                        Style="{DynamicResource NavButtonStyle}"
                        Click="SwitchView_Click" Tag="Day"
                        Margin="0,0,4,0" />
                <Button x:Name="WeekViewBtn"
                        Content="Week"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Click="SwitchView_Click" Tag="Week"
                        Margin="0,0,4,0" />
                <Button x:Name="MonthViewBtn"
                        Content="Month"
                        Style="{DynamicResource NavButtonStyle}"
                        Click="SwitchView_Click" Tag="Month" />

            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- Main content area -->
        <!-- ============================================================ -->
        <ContentControl x:Name="MainContent" />

    </DockPanel>
</Window>
