<Window x:Class="HomeschoolPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Homeschool Planner"
        Height="780" Width="1200"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <DockPanel>

        <!-- ============================================================ -->
        <!-- Menu bar -->
        <!-- ============================================================ -->
        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource SurfaceBrush}"
              Foreground="{DynamicResource TextPrimaryBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="0,0,0,1">
            <MenuItem Header="File" Foreground="{DynamicResource TextPrimaryBrush}">
                <MenuItem Header="Preferences" Click="Preferences_Click" />
                <Separator />
                <MenuItem Header="About" Click="About_Click" />
            </MenuItem>
            <MenuItem Header="School Settings" Foreground="{DynamicResource TextPrimaryBrush}"
                      Click="SchoolSettings_Click" />
            <MenuItem Header="Resources" Foreground="{DynamicResource TextPrimaryBrush}"
                      Click="Resources_Click" />
            <MenuItem Header="Reports" Foreground="{DynamicResource TextPrimaryBrush}"
                      Click="Reports_Click" />
        </Menu>

        <!-- ============================================================ -->
        <!-- Row 1: Student selector + management buttons -->
        <!-- ============================================================ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Single-student mode -->
                <StackPanel x:Name="SingleStudentPanel" Orientation="Horizontal">
                    <TextBlock Text="Student:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <ComboBox x:Name="StudentCombo"
                              Width="150"
                              DisplayMemberPath="Name"
                              SelectionChanged="StudentCombo_SelectionChanged" />
                </StackPanel>

                <!-- Split-view mode label -->
                <StackPanel x:Name="SplitViewPanel" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="Viewing:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock x:Name="SplitStudentLabel"
                               VerticalAlignment="Center" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>

                <Button x:Name="SplitViewBtn" Content="Split View"
                        Style="{DynamicResource NavButtonStyle}"
                        Margin="8,0,0,0"
                        ToolTip="View multiple students side by side"
                        Click="SplitView_Click" />

                <Button Content="Students"
                        Style="{DynamicResource NavButtonStyle}"
                        Margin="6,0,0,0"
                        Click="ManageStudents_Click" />

                <Button Content="Subjects"
                        Style="{DynamicResource NavButtonStyle}"
                        Margin="6,0,0,0"
                        Click="ManageSubjects_Click" />


            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- Row 2: Date navigation + view toggles -->
        <!-- ============================================================ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Center: Date navigation -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="&#8592;" Style="{DynamicResource NavButtonStyle}"
                            Width="32" Click="PrevPeriod_Click" />
                    <Button Content="Today"
                            Style="{DynamicResource NavButtonStyle}"
                            Margin="6,0"
                            Click="Today_Click" />
                    <TextBlock x:Name="PeriodLabel"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource AppFontSize}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="8,0"
                               MinWidth="220"
                               TextAlignment="Center" />
                    <Button Content="&#8594;" Style="{DynamicResource NavButtonStyle}"
                            Width="32" Click="NextPeriod_Click" />
                </StackPanel>

                <!-- Right: View toggles -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="DayViewBtn"
                            Content="Day"
                            Style="{DynamicResource NavButtonStyle}"
                            Click="SwitchView_Click" Tag="Day"
                            Margin="0,0,4,0" />
                    <Button x:Name="WeekViewBtn"
                            Content="Week"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Click="SwitchView_Click" Tag="Week"
                            Margin="0,0,4,0" />
                    <Button x:Name="MonthViewBtn"
                            Content="Month"
                            Style="{DynamicResource NavButtonStyle}"
                            Click="SwitchView_Click" Tag="Month" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content area -->
        <ContentControl x:Name="MainContent" />

    </DockPanel>
</Window>
